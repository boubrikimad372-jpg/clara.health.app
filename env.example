# ──────────────────────────────────────────────────────────────────────────────
# Clara Health App — Environment Variables
# ──────────────────────────────────────────────────────────────────────────────
#
# LOCAL DEVELOPMENT:
#   1. Copy this file to .env  →  cp .env.example .env
#   2. Fill in your key below
#   3. Run: vercel dev   (NOT vite dev — needed to run /api functions locally)
#
# VERCEL PRODUCTION:
#   Add GEMINI_API_KEY in:
#   Vercel Dashboard → Your Project → Settings → Environment Variables
#   ⚠️  Use exactly "GEMINI_API_KEY" — no VITE_ prefix
#   ⚠️  Redeploy after adding/changing the variable
#
# ──────────────────────────────────────────────────────────────────────────────

GEMINI_API_KEY=your_gemini_api_key_here
